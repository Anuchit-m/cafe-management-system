<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>จัดการออเดอร์</h2>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createOrderModal">
            สร้างออเดอร์ใหม่
        </button>
    </div>

    <!-- Orders List -->
    <div class="row">
        <div class="col-md-4">
            <div class="card">
                <div class="card-header bg-warning text-white">
                    <h5 class="card-title mb-0">รอดำเนินการ</h5>
                </div>
                <div class="card-body">
                    <% const pendingOrders = orders.filter(order => order.status === 'pending') %>
                    <% pendingOrders.forEach(order => { %>
                        <div class="order-card mb-3 p-3 border rounded">
                            <div class="d-flex justify-content-between">
                                <h6>ออเดอร์ #<%= order.orderNumber %></h6>
                                <span class="badge bg-warning">รอดำเนินการ</span>
                            </div>
                            <p class="mb-1">โต๊ะ: <%= order.tableNumber %></p>
                            <p class="mb-1">ลูกค้า: <%= order.customerName %></p>
                            <hr>
                            <% order.items.forEach(item => { %>
                                <div class="d-flex justify-content-between">
                                    <span><%= item.menu.name %> x <%= item.quantity %></span>
                                    <span>฿<%= item.price * item.quantity %></span>
                                </div>
                            <% }) %>
                            <hr>
                            <div class="d-flex justify-content-between">
                                <strong>รวม</strong>
                                <strong>฿<%= order.totalAmount %></strong>
                            </div>
                            <div class="mt-2">
                                <button class="btn btn-sm btn-success w-100 update-status" 
                                        data-id="<%= order._id %>" 
                                        data-status="preparing">
                                    เริ่มทำ
                                </button>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-header bg-info text-white">
                    <h5 class="card-title mb-0">กำลังทำ</h5>
                </div>
                <div class="card-body">
                    <% const preparingOrders = orders.filter(order => order.status === 'preparing') %>
                    <% preparingOrders.forEach(order => { %>
                        <div class="order-card mb-3 p-3 border rounded">
                            <div class="d-flex justify-content-between">
                                <h6>ออเดอร์ #<%= order.orderNumber %></h6>
                                <span class="badge bg-info">กำลังทำ</span>
                            </div>
                            <p class="mb-1">โต๊ะ: <%= order.tableNumber %></p>
                            <p class="mb-1">ลูกค้า: <%= order.customerName %></p>
                            <hr>
                            <% order.items.forEach(item => { %>
                                <div class="d-flex justify-content-between">
                                    <span><%= item.menu.name %> x <%= item.quantity %></span>
                                    <span>฿<%= item.price * item.quantity %></span>
                                </div>
                            <% }) %>
                            <hr>
                            <div class="d-flex justify-content-between">
                                <strong>รวม</strong>
                                <strong>฿<%= order.totalAmount %></strong>
                            </div>
                            <div class="mt-2">
                                <button class="btn btn-sm btn-success w-100 update-status" 
                                        data-id="<%= order._id %>" 
                                        data-status="completed">
                                    เสร็จสิ้น
                                </button>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-header bg-success text-white">
                    <h5 class="card-title mb-0">เสร็จสิ้น</h5>
                </div>
                <div class="card-body">
                    <% const completedOrders = orders.filter(order => order.status === 'completed') %>
                    <% completedOrders.forEach(order => { %>
                        <div class="order-card mb-3 p-3 border rounded">
                            <div class="d-flex justify-content-between">
                                <h6>ออเดอร์ #<%= order.orderNumber %></h6>
                                <span class="badge bg-success">เสร็จสิ้น</span>
                            </div>
                            <p class="mb-1">โต๊ะ: <%= order.tableNumber %></p>
                            <p class="mb-1">ลูกค้า: <%= order.customerName %></p>
                            <hr>
                            <% order.items.forEach(item => { %>
                                <div class="d-flex justify-content-between">
                                    <span><%= item.menu.name %> x <%= item.quantity %></span>
                                    <span>฿<%= item.price * item.quantity %></span>
                                </div>
                            <% }) %>
                            <hr>
                            <div class="d-flex justify-content-between">
                                <strong>รวม</strong>
                                <strong>฿<%= order.totalAmount %></strong>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>
        </div>
    </div>

    <!-- Create Order Modal -->
    <div class="modal fade" id="createOrderModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">สร้างออเดอร์ใหม่</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form action="/orders" method="POST">
                    <div class="modal-body">
                        <!-- Customer Info -->
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label">ชื่อลูกค้า</label>
                                <input type="text" class="form-control" name="customerName" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">เลขโต๊ะ</label>
                                <input type="text" class="form-control" name="tableNumber" required>
                            </div>
                        </div>
                        
                        <!-- Menu Selection -->
                        <div class="menu-items-container">
                            <h6 class="mb-3">รายการอาหาร</h6>
                            <% if (locals.menus && menus.length > 0) { %>
                                <% menus.forEach((menu, index) => { %>
                                    <div class="row mb-2 align-items-center">
                                        <div class="col-6">
                                            <label class="form-label"><%= menu.name %> (฿<%= menu.price %>)</label>
                                        </div>
                                        <div class="col-6">
                                            <input type="hidden" name="menuItems[<%= index %>][menuId]" value="<%= menu._id %>">
                                            <input type="number" 
                                                   class="form-control" 
                                                   name="menuItems[<%= index %>][quantity]" 
                                                   value="0" 
                                                   min="0">
                                        </div>
                                    </div>
                                <% }) %>
                            <% } else { %>
                                <p>ไม่พบรายการเมนู</p>
                            <% } %>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">ยกเลิก</button>
                        <button type="submit" class="btn btn-primary">บันทึก</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
// Update order status
document.querySelectorAll('.update-status').forEach(button => {
    button.addEventListener('click', async (e) => {
        const id = e.target.dataset.id;
        const status = e.target.dataset.status;
        try {
            const response = await fetch(`/orders/${id}/status`, {
                method: 'PUT',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ status })
            });
            if (response.ok) {
                window.location.reload();
            } else {
                throw new Error('Failed to update status');
            }
        } catch (error) {
            console.error('Error:', error);
            alert('เกิดข้อผิดพลาดในการอัพเดทสถานะ');
        }
    });
});
</script> 